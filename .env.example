# =============================================
# BOOGIE — Variables de Entorno Local
# =============================================
# 1. Copiar este archivo como .env.local
#    cp .env.example .env.local    (Linux/Mac)
#    copy .env.example .env.local  (Windows)
#
# 2. Completar los valores marcados con <...>
#
# 3. Iniciar con: .\dev.bat   o   .\dev.ps1
#    Frontend: http://localhost:3000
#    Backend:  http://localhost:8080
# =============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://<tu-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<anon-key>
SUPABASE_SECRET_KEY=<service-role-key>

# --- Base de Datos (Prisma) ---
DATABASE_URL="postgresql://postgres.<ref>:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.<ref>:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require"

# --- Aplicacion ---
# LOCAL: usar localhost. PRODUCCION: https://www.boogierent.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Boogie
NEXT_PUBLIC_APP_DESCRIPTION=Tu hogar lejos de casa en Venezuela

# --- Mapas (Mapbox) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.<tu-token>

# --- Email (Resend) ---
RESEND_API_KEY=re_<tu-api-key>
EMAIL_FROM=noreply@boogie.app

# --- Seguridad ---
NEXTAUTH_SECRET=<minimo-32-caracteres-aleatorios>
NEXTAUTH_URL=http://localhost:3000

# --- Sentry (deshabilitado en local) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- Comisiones ---
COMISION_PLATAFORMA_HUESPED=0.06
COMISION_PLATAFORMA_ANFITRION=0.03

# --- Flags ---
NEXT_PUBLIC_MANTENIMIENTO=false
NEXT_PUBLIC_PERMITIR_REGISTRO=true

# --- Cron ---
CRON_SECRET=<secret-aleatorio>

# --- CryptAPI ---
CRYPTAPI_WALLET_ADDRESS=<wallet-address>
CRYPTAPI_CALLBACK_SECRET=<callback-secret>

# --- Go Backend ---
GO_BACKEND_URL=http://localhost:8080
GO_BACKEND_EXCHANGE=true
GO_BACKEND_WEBHOOKS=true
GO_BACKEND_PROPIEDADES=true
GO_BACKEND_RESERVAS=true
GO_BACKEND_PAGOS=true
GO_BACKEND_REVIEWS=true
GO_BACKEND_VERIFICACION=true
GO_BACKEND_ADMIN=true
GO_BACKEND_AUTH=true
GO_BACKEND_CHAT=true
GO_BACKEND_OFERTAS=true
GO_BACKEND_WALLET=true
GO_BACKEND_TIENDA=true
GO_BACKEND_METODOS_PAGO=true
GO_BACKEND_PERFIL=true
GO_BACKEND_DASHBOARD=true
GO_BACKEND_SECCIONES=true

# --- MetaMap KYC ---
NEXT_PUBLIC_METAMAP_CLIENT_ID=<client-id>
NEXT_PUBLIC_METAMAP_FLOW_ID=<flow-id>
METAMAP_MERCHANT_ID=
METAMAP_WEBHOOK_SECRET=

# --- Datos de Pago (Bancarios) ---
PAYMENT_TRANSFERENCIA_BANCO=Banco de Venezuela
PAYMENT_TRANSFERENCIA_CUENTA=XXXX-XXXX-XXXX-XXXX
PAYMENT_TRANSFERENCIA_TITULAR=Boogie C.A.
PAYMENT_TRANSFERENCIA_CEDULA=J-XXXXXXXX
PAYMENT_PAGO_MOVIL_BANCO=Banco de Venezuela
PAYMENT_PAGO_MOVIL_TELEFONO=0414-XXX-XXXX
PAYMENT_PAGO_MOVIL_CEDULA=J-XXXXXXXX
PAYMENT_ZELLE_EMAIL=pagos@boogie.app
PAYMENT_ZELLE_NOMBRE=Boogie CA
PAYMENT_USDT_RED=TRC-20 (Tron)
PAYMENT_USDT_DIRECCION=TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
