# =============================================
# BOOGIE — Variables de Entorno
# Copiar este archivo como .env.local y completar
# =============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# --- Base de Datos (Prisma) ---
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

# --- Aplicacion ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Boogie
NEXT_PUBLIC_APP_DESCRIPTION=Tu hogar lejos de casa en Venezuela

# --- Mapas (Mapbox) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.tu-token-aqui

# --- Email (Resend) ---
RESEND_API_KEY=re_tu-api-key-aqui
EMAIL_FROM=noreply@boogie.app

# --- Seguridad ---
NEXTAUTH_SECRET=tu-secret-aqui-minimo-32-caracteres
NEXTAUTH_URL=http://localhost:3000

# --- Sentry (Error Tracking) ---
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=tu-sentry-auth-token-aqui

# --- Comisiones ---
COMISION_PLATAFORMA_HUESPED=0.06
COMISION_PLATAFORMA_ANFITRION=0.03

# --- Flags ---
NEXT_PUBLIC_MANTENIMIENTO=false
NEXT_PUBLIC_PERMITIR_REGISTRO=true

# --- Datos de Pago (Bancarios) ---
# Estos datos son usados internamente para mostrar al usuario al momento del pago
# NO son secretos pero son específicos de la plataforma
PAYMENT_TRANSFERENCIA_BANCO=Banco de Venezuela
PAYMENT_TRANSFERENCIA_CUENTA=XXXX-XXXX-XXXX-XXXX
PAYMENT_TRANSFERENCIA_TITULAR=Boogie C.A.
PAYMENT_TRANSFERENCIA_CEDULA=J-XXXXXXXX
PAYMENT_PAGO_MOVIL_BANCO=Banco de Venezuela
PAYMENT_PAGO_MOVIL_TELEFONO=0414-XXX-XXXX
PAYMENT_PAGO_MOVIL_CEDULA=J-XXXXXXXX
PAYMENT_ZELLE_EMAIL=pagos@boogie.app
PAYMENT_ZELLE_NOMBRE=Boogie CA
PAYMENT_USDT_RED=TRC-20 (Tron)
PAYMENT_USDT_DIRECCION=TXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Go Backend (Feature Flags) ---
GO_BACKEND_URL=http://localhost:8080
GO_BACKEND_EXCHANGE=false
GO_BACKEND_WEBHOOKS=false
GO_BACKEND_PROPIEDADES=false
GO_BACKEND_RESERVAS=false
GO_BACKEND_PAGOS=false
GO_BACKEND_REVIEWS=false
GO_BACKEND_VERIFICACION=false
GO_BACKEND_ADMIN=false
GO_BACKEND_AUTH=false
GO_BACKEND_CHAT=false
GO_BACKEND_OFERTAS=false
GO_BACKEND_WALLET=false
GO_BACKEND_TIENDA=false
GO_BACKEND_METODOS_PAGO=false
GO_BACKEND_PERFIL=false
GO_BACKEND_DASHBOARD=false
GO_BACKEND_SECCIONES=false
